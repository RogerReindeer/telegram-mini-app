# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
SYNC_TOKEN=CHANGE_ME

# Telegram Mini App bot
TELEGRAM_BOT_TOKEN=123456789:AA...

# Numeric IDs of the two private Telegram groups, usually beginning with -100.
# The bot must be an administrator in both groups.
TRAVELER_CHAT_ID=-1000000000001
KEEPER_CHAT_ID=-1000000000002

# Invite links shown in the paywall.
TRAVELER_JOIN_URL=https://t.me/+YOUR_TRAVELER_INVITE
KEEPER_JOIN_URL=https://t.me/+YOUR_KEEPER_INVITE

# Use a long random value. Do not reuse the bot token in production.
SESSION_SECRET=CHANGE_TO_A_LONG_RANDOM_SECRET
APP_ENV=production
AUTH_SESSION_TTL_SECONDS=900
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
MEMBERSHIP_CACHE_SECONDS=300
