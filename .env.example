APP_ENV=production
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SYNC_TOKEN=
SESSION_SECRET=
TELEGRAM_BOT_TOKEN=
TRAVELER_CHAT_ID=
KEEPER_CHAT_ID=
TRIBUTE_API_KEY=
TRIBUTE_TRAVELER_SUBSCRIPTION_ID=
TRIBUTE_KEEPER_SUBSCRIPTION_ID=
TRIBUTE_TRAVELER_URL=
TRIBUTE_KEEPER_URL=
CATALOG_CACHE_SECONDS=
TELEGRAPH_CACHE_SECONDS=
IMAGE_CACHE_SECONDS=

# Session/auth tuning. See app/config.py for defaults used when unset.
AUTH_SESSION_TTL_SECONDS=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=
MEMBERSHIP_CACHE_SECONDS=

# Exposes verbose Telegram-group/Tribute access diagnostics on /api/auth/debug.
# Defaults to true; production.py warns if this stays true in APP_ENV=production.
ACCESS_DEBUG_ENABLED=

APP_VERSION=
RATE_LIMIT_ENABLED=
RATE_LIMIT_WINDOW_SECONDS=
RATE_LIMIT_PUBLIC_MAX_REQUESTS=
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=
STATIC_CACHE_SECONDS=

# Optional runtime diagnostics. They log aggregate, non-secret operational events.
APP_EVENTS_ENABLED=
APP_METRICS_ENABLED=
